generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  role            UserRole
  avatarUrl       String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  clientMembers   ClientMember[]
  comments        Comment[]
  assignedIssues  Issue[]         @relation("AssignedTo")
  escalatedIssues Issue[]         @relation("EscalatedTo")
  raisedIssues    Issue[]         @relation("RaisedBy")
  issueHistory    IssueHistory[]
  knowledgeBase   KnowledgeBase[]
  notifications   Notification[]
  ledProjects     Project[]       @relation("AssignedLead")
  createdProjects Project[]       @relation("CreatedBy")
}

model Client {
  id            String          @id @default(cuid())
  name          String
  logoUrl       String?
  industry      String?
  contractStart DateTime?
  contractEnd   DateTime?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  members       ClientMember[]
  issues        Issue[]
  knowledgeBase KnowledgeBase[]
  projects      Project[]
  summaries     Summary[]
}

model ClientMember {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Project {
  id           String        @id @default(cuid())
  clientId     String
  name         String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  startDate    DateTime?
  endDate      DateTime?
  assignedLead String?
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  issues       Issue[]
  milestones   Milestone[]
  lead         User?         @relation("AssignedLead", fields: [assignedLead], references: [id])
  client       Client        @relation(fields: [clientId], references: [id])
  creator      User          @relation("CreatedBy", fields: [createdBy], references: [id])
  summaries    Summary[]
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id])
}

model SlaPolicy {
  id             String        @id @default(cuid())
  priority       IssuePriority @unique
  responseTime   Int
  resolutionTime Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Issue {
  id               String            @id @default(cuid())
  title            String
  description      String
  category         IssueCategory
  priority         IssuePriority     @default(MEDIUM)
  status           IssueStatus       @default(OPEN)
  clientId         String
  projectId        String?
  raisedById       String
  assignedToId     String?
  aiCategory       String?
  aiPriority       String?
  aiSuggestedAgent String?
  aiSummary        String?
  conversationSummary String?
  slaDueAt         DateTime?
  slaBreached      Boolean           @default(false)
  slaBreachRisk    Boolean           @default(false)
  escalated        Boolean           @default(false)
  escalatedAt      DateTime?
  escalatedToId    String?
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ticketKey        String?           @unique
  comments         Comment[]
  assignedTo       User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id])
  escalatedTo      User?             @relation("EscalatedTo", fields: [escalatedToId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  raisedBy         User              @relation("RaisedBy", fields: [raisedById], references: [id])
  attachments            IssueAttachment[]
  history                IssueHistory[]
  notifications          Notification[]
  similarResolutionsFor  SimilarResolution[] @relation("SimilarResolutionsFor")
  similarResolutionsFrom SimilarResolution[] @relation("SimilarResolutionsFrom")
}

model SimilarResolution {
  id                   String   @id @default(cuid())
  issueId              String
  similarResolvedId    String
  similarityScore      Int      // 0-100
  method               String   // "word" or "semantic"
  createdAt            DateTime @default(now())
  issue                Issue    @relation("SimilarResolutionsFor", fields: [issueId], references: [id], onDelete: Cascade)
  similarResolved      Issue    @relation("SimilarResolutionsFrom", fields: [similarResolvedId], references: [id], onDelete: Cascade)

  @@unique([issueId, similarResolvedId])
  @@index([issueId])
  @@index([similarResolvedId])
}

model IssueAttachment {
  id         String   @id @default(cuid())
  issueId    String
  commentId  String?
  uploadedBy String
  fileName   String
  fileUrl    String
  fileSize   Int?
  fileType   String?
  createdAt  DateTime @default(now())
  issue      Issue    @relation(fields: [issueId], references: [id])
  comment    Comment? @relation(fields: [commentId], references: [id])
}

model Comment {
  id            String    @id @default(cuid())
  issueId       String
  authorId      String
  content       String
  isInternal    Boolean   @default(false)
  isAiSuggested Boolean   @default(false)
  parentId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id])
  issue         Issue     @relation(fields: [issueId], references: [id])
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  attachments   IssueAttachment[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  issueId   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  issue     Issue?           @relation(fields: [issueId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model IssueHistory {
  id           String   @id @default(cuid())
  issueId      String
  changedById  String
  fieldChanged String
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())
  changedBy    User     @relation(fields: [changedById], references: [id])
  issue        Issue    @relation(fields: [issueId], references: [id])
}

model KnowledgeBase {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String?
  clientId    String?
  createdById String
  isPublished Boolean  @default(false)
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client?  @relation(fields: [clientId], references: [id])
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model Summary {
  id            String      @id @default(cuid())
  clientId      String
  projectId     String?
  periodStart   DateTime
  periodEnd     DateTime
  type          SummaryType
  content       String
  generatedByAi Boolean     @default(false)
  createdAt     DateTime    @default(now())
  client        Client      @relation(fields: [clientId], references: [id])
  project       Project?    @relation(fields: [projectId], references: [id])
}

enum UserRole {
  CLIENT_ADMIN
  CLIENT_USER
  THREESC_ADMIN
  THREESC_LEAD
  THREESC_AGENT
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum IssueCategory {
  FEATURE_REQUEST
  BUG
  DATA_ACCURACY
  PERFORMANCE
  ACCESS_SECURITY
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  ISSUE_ASSIGNED
  STATUS_UPDATED
  SLA_WARNING
  ESCALATION
  NEW_COMMENT
  ISSUE_RESOLVED
}

enum SummaryType {
  WEEKLY
  MONTHLY
}
